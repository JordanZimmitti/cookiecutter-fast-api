# File for adding or overwriting docker dev environment variables found in
# {{cookiecutter.package_name}}/core/settings.py

# Whether to add a color to the log line based on the log-level
IS_SHOW_LOG_LEVEL_COLORS=true

# The severity of logs to show
LOG_LEVEL=DEBUG

# The address that the api can be accessed from
LISTEN_ADDRESS=0.0.0.0

# {{cookiecutter.friendly_name}} server database and redis host
API_DB_HOST={{cookiecutter.package_name}}_postgres
API_REDIS_HOST={{cookiecutter.package_name}}_redis

# {{cookiecutter.friendly_name}} server database
API_DB_USER=local_user
API_DB_PASSWORD=very-secure-password

# {{cookiecutter.friendly_name}} server database migrations
TARGET_REVISION_ID=
API_DB_USER_MIGRATIONS=local_user
API_DB_PASSWORD_MIGRATIONS=very-secure-password
